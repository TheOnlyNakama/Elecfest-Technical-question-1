#include <Wire.h>

const int potPin = A0;
const int slaveAddress = 8;

void setup() {
  Wire.begin();        
  Serial.begin(9600);  
  Serial.println("Controller Initialized");
}

void loop() {
  int val = analogRead(potPin);

  Wire.beginTransmission(slaveAddress);
  Wire.write(highByte(val));
  Wire.write(lowByte(val));
  
  byte error = Wire.endTransmission();
  
  if (error == 0) {
    Serial.print("Sent: ");
    Serial.println(val);
  }

  delay(50); 
}
